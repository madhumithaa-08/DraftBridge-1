# App Configuration
APP_NAME=DraftBridge API
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=info

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# S3 — bucket will be auto-created on startup if it doesn't exist
S3_BUCKET_NAME=draftbridge-development-assets-YOUR_ACCOUNT_ID

# DynamoDB — table will be auto-created on startup if it doesn't exist
DYNAMODB_TABLE_NAME=draftbridge-designs

# Bedrock Model IDs
BEDROCK_TEXT_MODEL=us.amazon.nova-premier-v1:0
BEDROCK_IMAGE_MODEL=amazon.nova-canvas-v1:0
BEDROCK_VIDEO_MODEL=amazon.nova-reel-v1:0

# Limits
MAX_UPLOAD_SIZE_MB=10
PRESIGNED_URL_EXPIRY=3600
